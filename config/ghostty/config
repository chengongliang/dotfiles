# 字体族（要用 Ghostty 识别的名称）
# NFM 变体：Nerd 图标按单宽对齐，TUI/.statusline 列对齐更稳
font-family = JetBrainsMono Nerd Font Mono
# 中文回退：中英等宽对齐
font-family = Noto Sans Mono CJK SC

# 字号
font-size = 12
adjust-cell-width = 0
adjust-cell-height = 1
background-opacity=0.8
window-decoration = true
fullscreen = false
async-backend = epoll

# 分屏快捷键
keybind = alt+shift+minus=new_split:down
keybind = alt+shift+equal=new_split:right
keybind = alt+w=close_surface
