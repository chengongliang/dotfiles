# OS files
.DS_Store
Thumbs.db

# Editor temp files
*.swp
*.swo
*~

# Insurance: never track sensitive dirs
ssh/
gnupg/
kube/
.ssh/
.gnupg/
.kube/
home/.ssh/
home/.gnupg/
home/.kube/
*.pem
*.key
.env
.env.*

# Generated / cache
fish_variables
config/fish/conf.d/local.fish
*.back
backup/
lazy-lock.json
config/micro/backups/

# Host-specific niri display layout (outputs/positions vary by machine)
config/niri/cfg/display.kdl

# Herdr runtime files (logs, sockets, session state written into the config dir).
# Only config.toml is tracked; everything else herdr writes here is ignored.
config/herdr/*
!config/herdr/config.toml
